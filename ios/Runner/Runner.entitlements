<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Cho phép ứng dụng truy cập các private API ngoài Sandbox để tạo cửa sổ nổi -->
	<key>com.apple.private.security.no-sandbox</key>
	<true/>
	
	<!-- Các quyền quan trọng để đè cửa sổ nổi lên SpringBoard và các ứng dụng khác -->
	<key>com.apple.springboard.accessibility-window-hosting</key>
	<true/>
	<key>com.apple.springboard-ui.client</key>
	<true/>
	<key>com.apple.assistivetouch.daemon</key>
	<true/>
	<key>com.apple.accessibility.api</key>
	<true/>
	
	<!-- Cho phép chạy mã nguồn động (JIT) và cấp quyền tương tác phần cứng -->
	<key>run-unsigned-code</key>
	<true/>
	<key>get-task-allow</key>
	<true/>
</dict>
</plist>
