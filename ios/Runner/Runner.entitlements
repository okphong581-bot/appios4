<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Thoát sandbox → cho phép tạo UIWindow không bị hệ thống giới hạn -->
	<key>com.apple.private.security.no-sandbox</key>
	<true/>

	<!-- Quyền host window trên SpringBoard (accessibility layer) -->
	<key>com.apple.springboard.accessibility-window-hosting</key>
	<true/>

	<!-- Quyền truy cập SpringBoard UI services -->
	<key>com.apple.springboard-ui.client</key>
	<true/>

	<!-- Quyền platform application - cho phép window level cao nhất -->
	<key>platform-application</key>
	<true/>

	<!-- Quyền debug signals → giữ process alive khi background -->
	<key>com.apple.springboard.debugapplicationsandsignals</key>
	<true/>

	<!-- Cho phép JIT (dynamic code execution cho Flutter engine) -->
	<key>dynamic-codesigning</key>
	<true/>
	<key>run-unsigned-code</key>
	<true/>
	<key>get-task-allow</key>
	<true/>
</dict>
</plist>
